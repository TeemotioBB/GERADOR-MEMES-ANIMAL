# Grok / xAI
XAI_API_KEY=
XAI_MODEL=grok-4.5
XAI_BASE_URL=https://api.x.ai/v1
XAI_REASONING_EFFORT=low

# Proteção simples para uso pessoal. Defina os dois no Railway.
APP_USERNAME=admin
APP_PASSWORD=troque-esta-senha

# Limites e armazenamento temporário
MAX_BATCH_SIZE=50
JOB_TTL_HOURS=24
STORAGE_DIR=/tmp/cretino-factory
